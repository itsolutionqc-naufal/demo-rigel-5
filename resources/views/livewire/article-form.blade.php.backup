    <!-- Quill Editor JS -->
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script>
        lucide.createIcons();

        // Initialize Quill Editor
        document.addEventListener('DOMContentLoaded', function() {
            const quill = new Quill('#quill-editor', {
                theme: 'snow',
                modules: {
                    toolbar: '#quill-toolbar'
                },
                placeholder: 'Tulis konten artikel lengkap di sini...',
                formats: [
                    'header', 'font', 'size',
                    'bold', 'italic', 'underline', 'strike',
                    'color', 'background',
                    'list', 'bullet', 'align',
                    'link', 'image', 'code-block'
                ]
            });

            // Get initial content from Livewire
            const initialContent = @js($content ?? '');
            if (initialContent) {
                quill.root.innerHTML = initialContent;
            }

            // Sync content with Livewire on change
            quill.on('text-change', function() {
                const content = quill.root.innerHTML;

                // Update hidden input
                const hiddenInput = document.querySelector('input[wire\\:model="content"]');
                if (hiddenInput) {
                    hiddenInput.value = content;
                    // Trigger input event to notify Livewire
                    hiddenInput.dispatchEvent(new Event('input', { bubbles: true }));
                }
            });

            // Custom image handler
            const toolbar = quill.getModule('toolbar');
            toolbar.addHandler('image', function() {
                const input = document.createElement('input');
                input.setAttribute('type', 'file');
                input.setAttribute('accept', 'image/*');

                input.onchange = function() {
                    const file = this.files[0];

                    if (!file) {
                        return;
                    }

                    // Call Livewire to upload the file
                    @this.uploadImage(file).then(result => {
                        if (result.error) {
                            alert('Error uploading image: ' + result.error);
                            return;
                        }

                        // Insert image into editor at cursor position
                        const range = quill.getSelection(true);
                        quill.insertEmbed(range.index, 'image', result.url);
                        quill.setSelection(range.index + 1);
                    }).catch(error => {
                        alert('Error uploading image: ' + error);
                    });
                };

                input.click();
            });

            // Make Quill instance globally accessible
            window.quillInstance = quill;
        });
    </script>
</div>
