    <div class="space-y-6" wire:ignore.self x-data="{
        syncing: false,
        syncAndCall(method) {
            this.syncing = true;

            if (window.quillInstance) {
                const content = window.quillInstance.root.innerHTML;
                $wire.set('content', content).then(() => {
                    $wire.call(method);
                    this.syncing = false;
                });
            } else {
                $wire.call(method);
                this.syncing = false;
            }
        }
    }">
        <!-- Flash Messages -->
        @if(session()->has('success'))
