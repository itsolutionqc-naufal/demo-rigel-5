{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "rm -f public/hot && vite build",
        "dev": "vite",
        "cap:add:android": "cap add android",
        "cap:sync:android": "cap sync android",
        "cap:open:android": "cap open android",
        "cap:add:ios": "cap add ios",
        "cap:sync:ios": "cap sync ios",
        "cap:open:ios": "cap open ios",
        "ios:prepare": "npm run build && npm run cap:sync:ios",
        "ios:archive": "npm run ios:prepare && cd ios/App && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release -destination generic/platform=iOS -archivePath build/App.xcarchive archive"
    },
    "dependencies": {
        "@capacitor-community/fcm": "^7.3.0",
        "@capacitor/android": "^3.9.0",
        "@capacitor/app": "^4.1.1",
        "@capacitor/core": "^3.9.0",
        "@capacitor/ios": "^3.9.0",
        "@capacitor/local-notifications": "^7.0.6",
        "@capacitor/push-notifications": "^7.0.6",
        "@ionic/vue": "^8.8.4",
        "@ionic/vue-router": "^8.8.4",
        "@tailwindcss/vite": "^4.1.11",
        "autoprefixer": "^10.4.20",
        "axios": "^1.7.4",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0",
        "tailwindcss": "^4.0.7"
    },
    "optionalDependencies": {
        "@rollup/rollup-darwin-x64": "4.9.5",
        "@tailwindcss/oxide-darwin-x64": "^4.0.1",
        "lightningcss-darwin-x64": "^1.29.1"
    },
    "devDependencies": {
        "@capacitor/cli": "^3.9.0",
        "typescript": "^5.9.3",
        "vite": "^7.0.0",
        "vite-plugin-pwa": "^1.2.0"
    },
    "overrides": {
        "esbuild": "0.24.0"
    }
}
